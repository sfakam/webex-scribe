# webex-transcript-sync configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Webex Authentication ──────────────────────────────────────────────────────
# Option A (recommended): Personal Access Token from https://developer.webex.com
# No OAuth2 app required. Token expires after 12 hours for developer tokens;
# use an integration token for longer-lived access.
WEBEX_TOKEN=""

# Option B: OAuth2 integration credentials (only needed when WEBEX_TOKEN is not set).
# Create an integration at https://developer.webex.com/my-apps with scopes:
#   meeting:schedules_read  meeting:transcripts_read  meeting:summaries_read  spark:rooms_read
# Optional admin scope (requires org admin approval):
#   meeting:admin_transcript_read  meeting:admin_summaries_read
WEBEX_CLIENT_ID=""
WEBEX_CLIENT_SECRET=""

# ── Google Authentication ─────────────────────────────────────────────────────
# Required only when Application Default Credentials (gcloud auth) are not
# available. Create OAuth2 credentials at https://console.cloud.google.com
# under APIs & Services → Credentials → Create → OAuth client ID → Desktop app.
# Enable the Google Docs API and Google Drive API for your project.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Bot Mode (optional) ───────────────────────────────────────────────────────
# Used with --bot flag to list spaces the bot is a member of.
# Create a bot at https://developer.webex.com/my-apps → Create a Bot.
# Note: Webex bots cannot access meeting transcripts via the API — this is a
# platform limitation. The bot token is used only to list spaces.
WEBEX_BOT_TOKEN=""
WEBEX_BOT_ID=""
